# ─────────────────────────────────────────────────────
# FraudVault Environment Configuration
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in values before starting.
#   cp .env.example .env
#
# Generate random secrets:
#   openssl rand -hex 32
#
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────

# ── Required Secrets (no defaults — compose will not start without these) ──

POSTGRES_PASSWORD=           # Database password
REDIS_PASSWORD=              # Redis password
MINIO_ACCESS_KEY=            # MinIO access key (S3-compatible storage)
MINIO_SECRET_KEY=            # MinIO secret key
JWT_SECRET=                  # JWT signing secret (use: openssl rand -hex 32)
JWT_REFRESH_SECRET=          # Separate secret for refresh tokens (use: openssl rand -hex 32)
INTERNAL_API_KEY=            # Inter-service authentication key (use: openssl rand -hex 32)
ELASTICSEARCH_PASSWORD=      # Elasticsearch password

# ── General ──────────────────────────────────────────

NODE_ENV=production
LOG_LEVEL=info               # trace, debug, info, warn, error, fatal

# ── Authentication ───────────────────────────────────

JWT_EXPIRY=15m               # Access token lifetime
JWT_REFRESH_EXPIRY=7d        # Refresh token lifetime
BCRYPT_ROUNDS=12             # Password hashing rounds

# ── Threat Intelligence (all optional) ───────────────

VIRUSTOTAL_API_KEY=          # Free tier: 4 req/min, 500/day
MALWAREBAZAAR_API_KEY=       # abuse.ch MalwareBazaar
OTX_API_KEY=                 # AlienVault OTX
ABUSEIPDB_API_KEY=           # AbuseIPDB
HYBRID_ANALYSIS_API_KEY=     # Hybrid Analysis

# ── AI-Assisted Analysis (pick one, all optional) ────

OPENAI_COMPATIBLE_URL=       # Ollama/LM Studio endpoint (e.g., http://ollama:11434)
OPENAI_COMPATIBLE_MODEL=llama3
OPENAI_COMPATIBLE_API_KEY=not-needed
ANTHROPIC_API_KEY=           # Anthropic Claude
OPENAI_API_KEY=              # OpenAI GPT-4

# ── Sandbox ──────────────────────────────────────────

# Set to "true" to allow sandbox containers to use bridge network
# when user selects "simulated" or "controlled" mode.
# Default "false" = all sandboxes run with --network none (fully isolated).
SANDBOX_ALLOW_NETWORK=false

# ── Rate Limiting ────────────────────────────────────

RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window
