{
  "name": "scanboy",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise malware detonation and analysis platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace=@scanboy/api-gateway",
    "dev:orchestrator": "npm run dev --workspace=@scanboy/orchestrator",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "npm run clean --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "vitest": "^3.2.1"
  }
}
